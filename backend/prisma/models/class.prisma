model AcademicYear {
  id        String    @id @default(cuid())
  label     String    @unique // e.g. "2026-2027"
  startDate DateTime  @db.Date
  endDate   DateTime  @db.Date
  sections  Section[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Class {
  id       String    @id @default(cuid())
  name     String
  sections Section[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name])
}

model Section {
  id             String         @id @default(cuid())
  name           String
  class          Class          @relation(fields: [classId], references: [id])
  classId        String
  combination    Combination    @relation(fields: [combinationId], references: [id])
  combinationId  String
  language       SecondLanguage
  session        String         @default("A")
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id])
  academicYearId String

  classTeacher   User?  @relation("ClassTeacherOf", fields: [classTeacherId], references: [id])
  classTeacherId String? @unique

  students    User[]           @relation("StudentSection")
  subjects    SectionSubject[]
  attendances Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classId, combinationId, language, session, academicYearId])
}

model Subject {
  id       String           @id @default(cuid())
  name     String           @unique
  sections SectionSubject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SectionSubject {
  id        String  @id @default(cuid())
  section   Section @relation(fields: [sectionId], references: [id])
  sectionId String
  subject   Subject @relation(fields: [subjectId], references: [id])
  subjectId String
  teacher   User?   @relation("TeacherSubjects", fields: [teacherId], references: [id])
  teacherId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sectionId, subjectId])
}
