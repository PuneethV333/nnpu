generator client {
  provider = "prisma-client"
  output   = "../../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  role     Role    @default(Student)
  isActive Boolean @default(true)

  school   School? @relation(fields: [schoolId], references: [id])
  schoolId String?

  section   Section? @relation("StudentSection", fields: [sectionId], references: [id])
  sectionId String?

  auth               Auth?
  details            PersonalDetails?
  teachingSubjects   SectionSubject[] @relation("TeacherSubjects")
  studentAttendances Attendance[]     @relation("StudentAttendance")
  markedAttendances  Attendance[]     @relation("MarkedByTeacher")
  classTeacherOf     Section?         @relation("ClassTeacherOf")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
